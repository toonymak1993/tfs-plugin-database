{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toolsforsteam.dev/schemas/tfs-catalog.schema.json",
  "title": "Tools for Steam Community Catalog",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "title",
    "description",
    "plugins"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "title",
          "description",
          "version",
          "sdkVersion",
          "permissions",
          "packageSha256"
        ],
        "oneOf": [
          {
            "required": [
              "packageUrl"
            ]
          },
          {
            "required": [
              "packagePath"
            ]
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*[a-z0-9]$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "author": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "sdkVersion": {
            "type": "string",
            "const": "1.0.0"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "frontend",
                "storage",
                "secrets",
                "network",
                "files",
                "notifications",
                "logging",
                "native.audio",
                "native.processes",
                "native.display",
                "native.themes",
                "native.artwork",
                "native.app-start",
                "native.store-sync",
                "native.automation",
                "native.performance",
                "native.power",
                "native.full-trust"
              ]
            },
            "uniqueItems": true
          },
          "networkHosts": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(<local>|(\\*\\.)?[A-Za-z0-9](?:[A-Za-z0-9.-]*[A-Za-z0-9])?)$"
            },
            "uniqueItems": true
          },
          "packagePath": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?![A-Za-z]:)(?!/)(?!\\\\)(?!.*(^|[/\\\\])\\.\\.([/\\\\]|$)).+\\.zip$"
          },
          "packageUrl": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://.*\\.zip(\\?.*)?$"
          },
          "packageSha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "homepageUrl": {
            "type": "string",
            "format": "uri"
          },
          "repositoryUrl": {
            "type": "string",
            "format": "uri"
          },
          "changelog": {
            "type": "string",
            "maxLength": 4000
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "permissions": {
                  "contains": { "const": "network" }
                }
              }
            },
            "then": {
              "required": ["networkHosts"],
              "properties": {
                "networkHosts": { "minItems": 1 }
              }
            }
          }
        ]
      },
      "uniqueItems": true
    }
  }
}
